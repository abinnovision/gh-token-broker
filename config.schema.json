        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "permissions"
      ]
    },
    "permissions": {
      "properties": {
        "actions": {
          "enum": [
            "read",
            "write"
          ]
        },
        "administration": {
          "enum": [
            "read",
            "write"
          ]
        },
