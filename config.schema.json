          ]
        },
        "enterprise_custom_properties_for_organizations": {
          "enum": [
            "read",
            "write",
            "admin"
          ]
        },
        "environments": {
          "enum": [
            "read",
            "write"
          ]
        },
        "followers": {
          "enum": [
            "read",
            "write"
          ]
        },
        "git_ssh_keys": {
          "enum": [
            "read",
            "write"
          ]
        },
        "gpg_keys": {
          "enum": [
            "read",
            "write"
          ]
        },
        "interaction_limits": {
          "enum": [
            "read",
            "write"
          ]
        },
        "issues": {
          "enum": [
            "read",
            "write"
          ]
        },
        "members": {
          "enum": [
            "read",
