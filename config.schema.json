          ]
        },
        "pull_requests": {
          "enum": [
            "read",
            "write"
          ]
        },
        "repository_custom_properties": {
          "enum": [
            "read",
            "write"
          ]
        },
        "repository_hooks": {
          "enum": [
            "read",
            "write"
          ]
        },
        "repository_projects": {
          "enum": [
            "read",
            "write",
            "admin"
          ]
        },
        "secret_scanning_alerts": {
          "enum": [
            "read",
            "write"
          ]
        },
        "secrets": {
          "enum": [
            "read",
            "write"
          ]
        },
        "security_events": {
          "enum": [
            "read",
            "write"
          ]
        },
        "single_file": {
          "enum": [
            "read",
            "write"
          ]
        },
        "starring": {
          "enum": [
            "read",
            "write"
          ]
        },
        "statuses": {
          "enum": [
            "read",
            "write"
          ]
        },
        "vulnerability_alerts": {
          "enum": [
            "read",
            "write"
          ]
        },
        "workflows": {
          "enum": [
            "write"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "minProperties": 1
    },
    "policy": {
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "string",
          "minLength": 1,
          "description": "CEL expression evaluating to bool; the condition under which a policy contributes its grant"
        },
        "grant": {
          "$ref": "#/$defs/grant"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "condition",
        "grant"
      ]
    }
  },
  "properties": {
    "server": {
      "properties": {
        "bind": {
          "type": "string",
          "default": ":8080"
        },
        "issuer": {
          "type": "string",
          "description": "The broker's own OAuth issuer identifier — a stable absolute https:// URL used as the RFC 8414 'issuer' and as the base of token_endpoint."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "oidc": {
      "properties": {
        "issuer": {
          "type": "string",
          "default": "https://token.actions.githubusercontent.com"
        },
        "audience": {
          "type": "string",
          "minLength": 1,
          "description": "REQUIRED proxy-specific OIDC audience; tokens whose aud does not match exactly are rejected"
        },
        "clockSkewSeconds": {
          "type": "integer",
          "minimum": 0,
          "default": 60
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "audience"
      ]
    },
    "githubApp": {
      "properties": {
        "appId": {
          "type": "integer",
          "minimum": 1
        },
        "privateKeyPath": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the App private key PEM file. Never put raw key material in this YAML."
        },
        "privateKeyEnv": {
          "type": "string",
          "minLength": 1,
          "description": "Name of an environment variable holding the App private key PEM."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "appId"
      ]
    },
    "policy": {
      "properties": {
        "costLimit": {
          "type": "integer",
          "minimum": 1,
          "default": 10000
        },
        "maxRepositories": {
          "type": "integer",
          "minimum": 1,
          "default": 256
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "policies": {
      "items": {
        "$ref": "#/$defs/policy"
      },
      "type": "array"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "oidc",
    "githubApp"
  ],
  "title": "gh-token-broker configuration"
}
