{
  "openapi": "3.1.0",
  "info": {
    "title": "gh-token-broker",
    "description": "Authenticates GitHub Actions OIDC callers, evaluates CEL policy, and mints least-privilege GitHub App installation tokens.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/" }
  ],
  "security": [
    { "oidcBearer": [] }
  ],
  "paths": {
    "/token": {
      "post": {
        "summary": "RFC 8693 OAuth 2.0 Token Exchange",
        "description": "Exchanges a GitHub Actions OIDC ID token (`subject_token`) for a scoped GitHub App installation token. Only `grant_type=urn:ietf:params:oauth:grant-type:token-exchange` is supported; any other grant_type is rejected with `unsupported_grant_type`. Caller identity is verified from `subject_token`, not the `Authorization` header.",
        "operationId": "tokenExchange",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/TokenExchangeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token issued",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenExchangeResponse" }
              }
            }
          },
          "400": {
            "description": "invalid_request, unsupported_grant_type, invalid_grant, invalid_scope, or invalid_target",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthError" } } }
          },
          "502": {
            "description": "server_error: upstream GitHub API error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthError" } } }
          }
        }
      }
    },
    "/.well-known/oauth-authorization-server": {
      "get": {
        "summary": "RFC 8414 authorization server metadata",
        "operationId": "authorizationServerMetadata",
        "security": [],
        "responses": {
          "200": {
            "description": "Metadata document",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthorizationServerMetadata" }
              }
            }
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "summary": "Liveness check",
        "operationId": "healthz",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is up",
            "content": { "text/plain": { "schema": { "type": "string", "example": "ok" } } }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "summary": "This OpenAPI document",
        "operationId": "openapiSpec",
        "security": [],
        "responses": {
          "200": {
            "description": "The OpenAPI document",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oidcBearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "GitHub Actions OIDC token (`id-token: write` in the calling workflow)."
      }
    },
    "schemas": {
      "TokenExchangeRequest": {
        "type": "object",
        "required": ["grant_type", "subject_token", "subject_token_type", "resource"],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["urn:ietf:params:oauth:grant-type:token-exchange"]
          },
          "subject_token": {
            "type": "string",
            "description": "The GitHub Actions OIDC ID token identifying the caller."
          },
          "subject_token_type": {
            "type": "string",
            "enum": ["urn:ietf:params:oauth:token-type:id_token"]
          },
          "resource": {
            "type": "array",
            "items": { "type": "string" },
            "description": "One `owner/repo` value per target repository (repeated form key). All values must share one owner.",
            "example": ["acme/app"]
          },
          "audience": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional; if present every value must equal the owner derived from resource."
          },
          "scope": {
            "type": "string",
            "description": "Space-delimited `permission:level` tokens, e.g. \"contents:write issues:read\".",
            "example": "contents:read"
          },
          "requested_token_type": {
            "type": "string",
            "enum": ["urn:ietf:params:oauth:token-type:access_token"]
          }
        },
        "additionalProperties": false
      },
      "TokenExchangeResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "issued_token_type": {
            "type": "string",
            "enum": ["urn:ietf:params:oauth:token-type:access_token"]
          },
          "token_type": { "type": "string", "example": "bearer" },
          "expires_in": { "type": "integer", "description": "Seconds until expiry." },
          "scope": {
            "type": "string",
            "description": "Present only when the granted scope differs from the requested scope."
          }
        }
      },
      "OAuthError": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string",
            "enum": ["invalid_request", "unsupported_grant_type", "invalid_grant", "invalid_scope", "invalid_target", "server_error"]
          },
          "error_description": { "type": "string" }
        }
      },
      "AuthorizationServerMetadata": {
        "type": "object",
        "properties": {
          "issuer": { "type": "string", "format": "uri" },
          "token_endpoint": { "type": "string", "format": "uri" },
          "grant_types_supported": {
            "type": "array",
            "items": { "type": "string" }
          },
          "token_endpoint_auth_methods_supported": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
